{
  "name": "devchef",
  "version": "7.0.0",
  "description": "DevChef V7 - State-of-the-art developer productivity platform with flawless UX",
  "type": "module",
  "scripts": {
    "start": "node scripts/start-devchef.mjs",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "generate:tools-readme": "node scripts/generate-tool-readme.mjs"
  },
  "keywords": [
    "developer-tools",
    "productivity",
    "offline"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "happy-dom": "^20.9.0",
    "vitest": "^2.1.9"
  }
}
